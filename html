<!DOCTYPE html>
<html>
<head>
    <title>Fact Kahoot</title>
    <style>
        body {
            font-family: Arial;
            text-align: center;
            background: #121212;
            color: white;
        }

        .btn {
            padding: 15px;
            margin: 10px;
            width: 200px;
            font-size: 18px;
            border: none;
            border-radius: 10px;
            cursor: pointer;
        }

        .true { background: #4CAF50; }
        .false { background: #f44336; }

        #score {
            font-size: 24px;
            margin: 20px;
        }
    </style>
</head>
<body>

<h1>🎮 Fact Quiz (Kahoot style)</h1>

<div id="score">Score: 0</div>

<h2 id="question">Loading...</h2>

<button class="btn true" onclick="answer(true)">TRUE</button>
<button class="btn false" onclick="answer(false)">FALSE</button>

<script>
let currentAnswer = null;
let score = 0;

async function loadQuestion() {
    const res = await fetch("/question");
    const data = await res.json();

    document.getElementById("question").innerText = data.question;
    currentAnswer = data.correct_answer;
}

function answer(userAnswer) {
    if (userAnswer == currentAnswer) {
        score += 100;
        alert("✅ Correct!");
    } else {
        alert("❌ Wrong!");
    }

    document.getElementById("score").innerText = "Score: " + score;
    loadQuestion();
}

loadQuestion();
</script>

</body>
</html>